<script>
  // ── Main tab switching ──
  function switchMain(tab) {
    const countries = document.getElementById('countriesSection');
    const personal  = document.getElementById('personalSection');
    const tabC = document.getElementById('tabCountries');
    const tabP = document.getElementById('tabPersonal');

    if (tab === 'countries') {
      countries.classList.add('visible');
      personal.classList.remove('visible');
      tabC.classList.add('active-countries');
      tabP.classList.remove('active-personal');
    } else {
      personal.classList.add('visible');
      countries.classList.remove('visible');
      tabP.classList.add('active-personal');
      tabC.classList.remove('active-countries');
    }
  }

  // ── Country / vocab card toggle ──
  function toggleCard(el) {
    el.classList.toggle('done');
  }
  function resetGrid(gridId) {
    document.getElementById(gridId).querySelectorAll('.country-card, .answer-card').forEach(el => {
      el.classList.remove('done');
    });
  }

  // ── Answer card toggle (inside accordion) ──
  function toggleAnswer(el) {
    el.classList.toggle('done');
  }

  // ── Question accordion: only one open at a time ──
  function toggleQuestion(id) {
    const card = document.querySelector('.q-card[data-id="' + id + '"]');
    const answer = document.getElementById('ans-' + id);
    const isOpen = card.classList.contains('open');

    document.querySelectorAll('.q-card').forEach(c => c.classList.remove('open'));
    document.querySelectorAll('.q-answer').forEach(a => a.style.display = 'none');

    if (!isOpen) {
      card.classList.add('open');
      answer.style.display = 'block';
    }
  }

  function resetPersonalPractice() {
    ['p1','p2','p3','p4'].forEach(id => document.getElementById(id).value = '');
  }
</script>
</body>
