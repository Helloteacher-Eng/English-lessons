<script>
// ══════════════════════════════════
// NAVIGATION
// ══════════════════════════════════
const SECS = ['alpha','name','days'];

function goSection(s){
  SECS.forEach(x=>{
    document.getElementById('p-'+x).classList.toggle('on', x===s);
    document.getElementById('nv-'+x).classList.toggle('on', x===s);
  });
}

function goSub(t){
  ['t1','t2'].forEach(x=>{
    document.getElementById('st'+x[1]).classList.toggle('on', x===t);
    document.getElementById('sp-'+x).classList.toggle('on', x===t);
  });
}

// ══════════════════════════════════
// SPEECH
// ══════════════════════════════════
function speak(txt,rate){
  if(!window.speechSynthesis) return;
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(txt);
  u.lang='en-US'; u.rate=rate||0.88;
  speechSynthesis.speak(u);
}

// ══════════════════════════════════
// TASK 1 – MISSING LETTERS
// ══════════════════════════════════
const MISSING = new Set(['B','E','H','L','N','Q','U','W','Y']);
const ALPHA = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

function buildAlpha(){
  const g=document.getElementById('alphaGrid');
  g.innerHTML='';
  ALPHA.forEach(lt=>{
    if(MISSING.has(lt)){
      const inp=document.createElement('input');
      inp.className='a-inp';
      inp.maxLength=1;
      inp.dataset.l=lt;
      inp.setAttribute('autocomplete','off');
      inp.setAttribute('autocapitalize','characters');
      inp.addEventListener('input',function(){
        const v=this.value.toUpperCase();
        this.value=v;
        if(v===lt){
          this.classList.add('ok');this.classList.remove('bad');
          speak(lt);
          // advance
          const all=[...document.querySelectorAll('.a-inp')];
          const i=all.indexOf(this);
          if(i<all.length-1) all[i+1].focus();
        } else if(v){
          this.classList.add('bad');this.classList.remove('ok');
        } else {
          this.classList.remove('ok','bad');
        }
      });
      g.appendChild(inp);
    } else {
      const d=document.createElement('div');
      d.className='a-fixed';
      d.textContent=lt;
      d.title='Click to hear';
      d.onclick=()=>speak(lt);
      g.appendChild(d);
    }
  });
}

function revealAlpha(){
  document.querySelectorAll('.a-inp').forEach(i=>{
    i.value=i.dataset.l;
    i.classList.add('ok');i.classList.remove('bad');
  });
}
function resetAlpha(){
  document.querySelectorAll('.a-inp').forEach(i=>{
    i.value='';i.classList.remove('ok','bad');
  });
}

// ══════════════════════════════════
// TASK 2 – SOUND GROUPS
// ══════════════════════════════════
const SG=[
  {lbl:'/-ay/', lets:['A','H','J','K']},
  {lbl:'/-ee/', lets:['B','C','D','E','G','P','T','V','Z']},
  {lbl:'/e-/',  lets:['F','L','M','N','S','X']},
  {lbl:'/-ai/', lets:['I','Y']},
  {lbl:'/oh/',  lets:['O']},
  {lbl:'/you/', lets:['Q','U','W']},
  {lbl:'/ar/',  lets:['R']}
];
const L2G={};
SG.forEach((g,i)=>g.lets.forEach(l=>L2G[l]=i));

let selLet=null;
const placed=new Set();

function buildSG(){
  const grid=document.getElementById('sgGrid');
  grid.innerHTML='';
  SG.forEach((g,i)=>{
    const col=document.createElement('div');
    col.className='sg-col';
    col.innerHTML=`<div class="sg-head" id="sh${i}">${g.lbl}</div><div class="sg-zone" id="sz${i}"></div>`;
    col.onclick=()=>dropInto(i);
    grid.appendChild(col);
  });
  buildPool();
}

function buildPool(){
  const pool=document.getElementById('lPool');
  pool.innerHTML='';
  const sc=[...ALPHA].sort(()=>Math.random()-.5);
  sc.forEach(lt=>{
    const c=document.createElement('div');
    c.className='chip';
    c.id='ch-'+lt;
    c.textContent=lt;
    c.onclick=e=>{e.stopPropagation();pickLet(lt,c)};
    pool.appendChild(c);
  });
}

function pickLet(lt,el){
  if(placed.has(lt)) return;
  if(selLet){
    const prev=document.getElementById('ch-'+selLet);
    if(prev) prev.classList.remove('sel');
    document.querySelectorAll('.sg-zone').forEach(z=>z.classList.remove('ready'));
    document.querySelectorAll('.sg-head').forEach(h=>h.classList.remove('glow'));
  }
  selLet=lt;
  el.classList.add('sel');
  speak(lt);
  document.getElementById('selInfo').textContent=`"${lt}" selected — now click the right sound group above ↑`;
  document.querySelectorAll('.sg-zone').forEach(z=>z.classList.add('ready'));
  document.querySelectorAll('.sg-head').forEach(h=>h.classList.add('glow'));
}

function dropInto(gi){
  if(!selLet){
    document.getElementById('selInfo').textContent='👆 First click a letter from the pool below';
    return;
  }
  const chip=document.getElementById('ch-'+selLet);
  if(L2G[selLet]===gi){
    // correct
    const p=document.createElement('div');
    p.className='placed';p.textContent=selLet;
    document.getElementById('sz'+gi).appendChild(p);
    if(chip) chip.style.visibility='hidden';
    placed.add(selLet);
    speak('Correct! '+selLet);
    document.getElementById('selInfo').textContent='✅ Correct! Pick another letter.';
    document.querySelectorAll('.sg-zone').forEach(z=>z.classList.remove('ready'));
    document.querySelectorAll('.sg-head').forEach(h=>h.classList.remove('glow'));
    selLet=null;
    if(placed.size===26){
      setTimeout(()=>{
        document.getElementById('selInfo').textContent='🎉 All 26 letters sorted! Amazing!';
        speak('Amazing! You sorted all 26 letters!');
      },400);
    }
  } else {
    // wrong
    if(chip){
      chip.classList.remove('sel');
      chip.classList.add('shk');
      setTimeout(()=>{chip.classList.remove('shk');chip.classList.add('sel')},450);
    }
    document.getElementById('selInfo').textContent=`❌ Not quite — try a different group for "${selLet}"`;
    speak('Try again');
  }
}

function revealSG(){
  ALPHA.forEach(lt=>{
    if(!placed.has(lt)){
      const p=document.createElement('div');
      p.className='placed';p.textContent=lt;
      document.getElementById('sz'+L2G[lt]).appendChild(p);
      const ch=document.getElementById('ch-'+lt);
      if(ch) ch.style.visibility='hidden';
      placed.add(lt);
    }
  });
  selLet=null;
  document.getElementById('selInfo').textContent='👁️ All letters revealed!';
  document.querySelectorAll('.sg-zone').forEach(z=>z.classList.remove('ready'));
  document.querySelectorAll('.sg-head').forEach(h=>h.classList.remove('glow'));
}

function resetSG(){
  placed.clear();selLet=null;
  document.getElementById('selInfo').textContent='👆 Start by clicking a letter from the pool below';
  buildSG();
}

// ══════════════════════════════════
// MY NAME
// ══════════════════════════════════
function normSpell(s){ return s.replace(/[-\s.]/g,'').toUpperCase(); }

function clrN(a,b){
  [a,b].forEach(id=>{
    const el=document.getElementById(id);
    if(el){ el.classList.remove('ok','bad'); }
  });
  document.getElementById('nameHint').classList.remove('on');
}

function checkName(){
  const vals=['n1','n2','n3','n4'].map(id=>document.getElementById(id).value.trim());
  const [v1,v2,v3,v4]=vals;
  let ok=true;
  const hints=[];

  // Q1 first name
  if(v1){ setNI('n1',true); } else { setNI('n1',false); ok=false; }

  // Q2 spelling of first name
  if(v1 && normSpell(v2)===normSpell(v1)){ setNI('n2',true); }
  else { setNI('n2',false); ok=false;
    if(v1) hints.push(`💡 Spell "<strong>${v1.toUpperCase()}</strong>" as: <strong>${v1.toUpperCase().split('').join('-')}</strong>`);
  }

  // Q3 last name
  if(v3){ setNI('n3',true); } else { setNI('n3',false); ok=false; }

  // Q4 spelling of last name
  if(v3 && normSpell(v4)===normSpell(v3)){ setNI('n4',true); }
  else { setNI('n4',false); ok=false;
    if(v3) hints.push(`💡 Spell "<strong>${v3.toUpperCase()}</strong>" as: <strong>${v3.toUpperCase().split('').join('-')}</strong>`);
  }

  if(hints.length){
    const h=document.getElementById('nameHint');
    h.innerHTML=hints.join('<br>');
    h.classList.add('on');
  }
  if(ok){ setTimeout(celebrate,150); }
}

function setNI(id,good){
  const el=document.getElementById(id);
  el.classList.toggle('ok',good);
  el.classList.toggle('bad',!good);
}

function resetName(){
  ['n1','n2','n3','n4'].forEach(id=>{
    const el=document.getElementById(id);
    el.value='';el.classList.remove('ok','bad');
  });
  document.getElementById('nameHint').classList.remove('on');
}

// ══════════════════════════════════
// DAY MATH
// ══════════════════════════════════
const DAYS=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
const DAY_PROBS=[
  {q:'Monday + 2 days =',  a:'Wednesday', ex:true},
  {q:'Thursday \u2013 3 days =', a:'Monday'},
  {q:'Friday + 1 day =',   a:'Saturday'},
  {q:'Sunday + 2 days =',  a:'Tuesday'},
  {q:'Saturday \u2013 1 day =', a:'Friday'},
  {q:'Saturday + 5 days =',a:'Thursday'}
];

function buildDays(){
  const c=document.getElementById('dayProbs');
  c.innerHTML='';
  DAY_PROBS.forEach((p,i)=>{
    const row=document.createElement('div');
    row.className='day-row'+(p.ex?' eg':'');
    if(p.ex){
      row.innerHTML=`<span class="day-num">${i+1}.</span><span class="day-eq">${p.q}</span><span class="day-ans">✅ ${p.a}</span><span style="font-size:12px;color:#16a34a;margin-left:4px">(example)</span>`;
    } else {
      row.innerHTML=`<span class="day-num">${i+1}.</span><span class="day-eq">${p.q}</span><input class="day-input" id="dp${i}" data-a="${p.a}" placeholder="day..." autocomplete="off" onkeydown="if(event.key==='Enter'){event.preventDefault();chkDay(this)}" oninput="clrDay(this)"/>`;
    }
    c.appendChild(row);
  });
}

function chkDay(inp){
  const v=inp.value.trim();
  const a=inp.dataset.a;
  if(v.toLowerCase()===a.toLowerCase()){
    inp.classList.add('ok');inp.classList.remove('bad');
    speak('Correct! '+a);
  } else if(v){
    inp.classList.add('bad');inp.classList.remove('ok');
  }
}

function clrDay(inp){ inp.classList.remove('ok','bad'); }

function checkDays(){ document.querySelectorAll('.day-input').forEach(chkDay); }

function revealDays(){
  document.querySelectorAll('.day-input').forEach(i=>{
    i.value=i.dataset.a;
    i.classList.add('ok');i.classList.remove('bad');
  });
}

function resetDays(){
  document.querySelectorAll('.day-input').forEach(i=>{
    i.value='';i.classList.remove('ok','bad');
  });
}

function speakDays(){ speak(DAYS.join(', '), 0.7); }

// ══════════════════════════════════
// CELEBRATION
// ══════════════════════════════════
let celAnimId=null;

function celebrate(){
  const cel=document.getElementById('cel');
  cel.classList.remove('off');cel.classList.add('on');
  const cv=document.getElementById('cel-canvas');
  cv.width=window.innerWidth; cv.height=window.innerHeight;
  const ctx=cv.getContext('2d');
  const COLS=['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#c77dff','#ff9f43','#48dbfb'];
  const pts=[];
  for(let i=0;i<200;i++) pts.push({
    x:Math.random()*cv.width, y:cv.height*0.7+Math.random()*200,
    vx:(Math.random()-.5)*9, vy:-(Math.random()*12+4),
    col:COLS[Math.floor(Math.random()*COLS.length)],
    sz:Math.random()*10+4, gv:0.18, al:1,
    rot:Math.random()*360, rs:(Math.random()-.5)*9,
    sh:Math.random()<.5
  });
  let fr=0;
  function draw(){
    if(fr>240){ctx.clearRect(0,0,cv.width,cv.height);return;}
    ctx.clearRect(0,0,cv.width,cv.height);
    pts.forEach(p=>{
      p.x+=p.vx; p.y+=p.vy; p.vy+=p.gv;
      p.vx*=.99; p.al=Math.max(0,1-fr/220);
      p.rot+=p.rs;
      ctx.save();
      ctx.globalAlpha=p.al;
      ctx.translate(p.x,p.y);
      ctx.rotate(p.rot*Math.PI/180);
      ctx.fillStyle=p.col;
      if(p.sh){ ctx.beginPath();ctx.arc(0,0,p.sz/2,0,Math.PI*2);ctx.fill(); }
      else { ctx.fillRect(-p.sz/2,-p.sz*.3,p.sz,p.sz*.6); }
      ctx.restore();
    });
    fr++; celAnimId=requestAnimationFrame(draw);
  }
  draw();
  clap();
  speak('Excellent! Your name is spelled perfectly!');
}

function closeCel(){
  const cel=document.getElementById('cel');
  cel.classList.remove('on');cel.classList.add('off');
  if(celAnimId){ cancelAnimationFrame(celAnimId);celAnimId=null; }
  const cv=document.getElementById('cel-canvas');
  cv.getContext('2d').clearRect(0,0,cv.width,cv.height);
}

function clap(){
  try{
    const AC=window.AudioContext||window.webkitAudioContext;
    if(!AC) return;
    const a=new AC();
    [0,.42,.84,1.26,1.68].forEach(t=>{
      const buf=a.createBuffer(1,Math.floor(a.sampleRate*.13),a.sampleRate);
      const d=buf.getChannelData(0);
      for(let i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2)*.9;
      const src=a.createBufferSource();
      const gain=a.createGain();
      gain.gain.setValueAtTime(.85,a.currentTime+t);
      gain.gain.exponentialRampToValueAtTime(.001,a.currentTime+t+.13);
      src.buffer=buf;src.connect(gain);gain.connect(a.destination);
      src.start(a.currentTime+t);
    });
  }catch(e){}
}

