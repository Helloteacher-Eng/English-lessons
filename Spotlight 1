<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#FF8C42">
<title>Meet My Family - English Lesson</title>
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  :root {
    --primary: #FF8C42;
    --primary-dark: #E67A30;
    --secondary: #4ECDC4;
    --accent: #FFD93D;
    --bg: #FFF8F0;
    --card: #FFFFFF;
    --text: #2D3436;
    --text-light: #636E72;
    --success: #6BCB77;
    --error: #FF6B6B;
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  html, body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ===== FIXED HEADER ===== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 14px 16px 12px;
    z-index: 100;
    box-shadow: var(--shadow);
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    gap: 8px;
  }

  .lesson-title {
    font-size: 1.15rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }

  .lesson-title::before {
    content: "👨‍👩‍👧‍👦";
    font-size: 1.4rem;
  }

  .header-stats {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .star-counter {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 255, 255, 0.2);
    padding: 4px 10px;
    border-radius: 20px;
    transition: transform 0.2s ease;
  }

  .star-counter::before {
    content: "⭐";
    font-size: 1rem;
  }

  .reset-btn {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: white;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .reset-btn:active {
    background: rgba(255, 255, 255, 0.35);
    transform: rotate(-180deg);
  }

  .progress-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .progress-bar {
    flex: 1;
    height: 10px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent) 0%, #FFB84D 100%);
    border-radius: 10px;
    transition: width 0.5s ease;
    box-shadow: 0 0 8px rgba(255, 217, 61, 0.6);
  }

  .progress-percent {
    font-size: 0.85rem;
    font-weight: 700;
    min-width: 40px;
    text-align: right;
  }

  /* ===== TAB NAVIGATION ===== */
  .tab-nav {
    position: fixed;
    top: 88px;
    left: 0;
    right: 0;
    background: var(--card);
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    z-index: 99;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .tab-nav::-webkit-scrollbar {
    display: none;
  }

  .tab-btn {
    flex: 1;
    min-width: 80px;
    padding: 12px 8px;
    background: none;
    border: none;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-light);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    position: relative;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .tab-btn .tab-icon {
    font-size: 1.4rem;
    transition: transform 0.3s ease;
  }

  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: var(--primary);
    border-radius: 3px 3px 0 0;
    transition: width 0.3s ease;
  }

  .tab-btn.active {
    color: var(--primary);
  }

  .tab-btn.active .tab-icon {
    transform: scale(1.15);
  }

  .tab-btn.active::after {
    width: 60%;
  }

  .tab-btn:active {
    background: rgba(255, 140, 66, 0.08);
  }

  .tab-btn.completed::before {
    content: "✓";
    position: absolute;
    top: 6px;
    right: 8px;
    background: var(--success);
    color: white;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ===== MAIN CONTENT ===== */
  main {
    padding: 170px 16px 30px;
    max-width: 720px;
    margin: 0 auto;
  }

  .section {
    display: none;
    animation: fadeIn 0.4s ease;
  }

  .section.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .section-header {
    text-align: center;
    margin-bottom: 20px;
  }

  .section-header h2 {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 4px;
  }

  .section-header p {
    color: var(--text-light);
    font-size: 0.95rem;
  }

  /* ===== LEARN SECTION - VOCAB CARDS ===== */
  .vocab-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .vocab-card {
    background: var(--card);
    border-radius: 20px;
    padding: 18px 12px;
    box-shadow: var(--shadow);
    text-align: center;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    border: 3px solid transparent;
    position: relative;
    overflow: hidden;
  }

  .vocab-card:active {
    transform: scale(1.05);
    box-shadow: var(--shadow-lg);
  }

  .vocab-card.listened {
    border-color: var(--success);
  }

  .vocab-card.listened::after {
    content: "✓";
    position: absolute;
    top: 8px;
    right: 10px;
    background: var(--success);
    color: white;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    font-size: 0.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vocab-emoji {
    font-size: 3.5rem;
    line-height: 1;
  }

  .vocab-word {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    text-transform: capitalize;
  }

  .vocab-listen-btn {
    background: var(--primary);
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: background 0.2s ease, transform 0.2s ease;
    font-family: inherit;
  }

  .vocab-listen-btn:active {
    background: var(--primary-dark);
    transform: scale(0.95);
  }

  /* ===== LISTEN SECTION ===== */
  .listen-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .listen-btn {
    background: linear-gradient(135deg, #FFFFFF 0%, #FFF5EB 100%);
    border: 3px solid var(--primary);
    border-radius: 20px;
    padding: 18px 20px;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--primary-dark);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: all 0.2s ease;
    font-family: inherit;
    box-shadow: var(--shadow);
    text-align: left;
  }

  .listen-btn:active {
    transform: scale(0.98);
  }

  .listen-btn .listen-emoji {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .listen-btn .listen-word {
    flex: 1;
    text-transform: capitalize;
  }

  .listen-btn .listen-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      box-shadow: var(--shadow);
    }
    50% {
      transform: scale(1.03);
      box-shadow: 0 0 20px rgba(255, 140, 66, 0.5);
    }
  }

  @keyframes speakerWave {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.2); }
    50% { transform: scale(0.95); }
    75% { transform: scale(1.15); }
  }

  .listen-btn.speaking {
    animation: pulse 0.8s ease-in-out infinite;
    background: linear-gradient(135deg, #FFF5EB 0%, #FFE4CC 100%);
    border-color: var(--primary-dark);
  }

  .listen-btn.speaking .listen-icon {
    animation: speakerWave 0.6s ease-in-out infinite;
  }

  /* ===== MATCH SECTION ===== */
  .match-instruction {
    background: var(--card);
    border-radius: 16px;
    padding: 14px 18px;
    margin-bottom: 16px;
    text-align: center;
    box-shadow: var(--shadow);
    font-weight: 600;
    color: var(--text);
  }

  .match-instruction .inst-icon {
    font-size: 1.3rem;
    margin-right: 6px;
  }

  .match-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .match-column {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .match-column-title {
    text-align: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .match-item {
    background: var(--card);
    border: 3px solid #E0E0E0;
    border-radius: 16px;
    padding: 16px 10px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: inherit;
    box-shadow: var(--shadow);
    min-height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .match-item .match-emoji {
    font-size: 2.2rem;
  }

  .match-item.selected {
    border-color: var(--primary);
    background: #FFF5EB;
    transform: scale(1.05);
    box-shadow: 0 0 0 4px rgba(255, 140, 66, 0.2);
  }

  .match-item.correct {
    border-color: var(--success);
    background: #E8F8EA;
    color: var(--success);
    pointer-events: none;
    position: relative;
  }

  .match-item.correct::after {
    content: "✓";
    position: absolute;
    top: 4px;
    right: 8px;
    font-size: 1.2rem;
    font-weight: 900;
    color: var(--success);
  }

  .match-item.wrong {
    border-color: var(--error);
    background: #FFE8E8;
    animation: shake 0.4s ease;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-8px); }
    40% { transform: translateX(8px); }
    60% { transform: translateX(-6px); }
    80% { transform: translateX(6px); }
  }

  .match-complete {
    background: linear-gradient(135deg, var(--success) 0%, #4CAF50 100%);
    color: white;
    padding: 20px;
    border-radius: 20px;
    text-align: center;
    margin-top: 16px;
    box-shadow: var(--shadow-lg);
    animation: fadeIn 0.5s ease;
  }

  .match-complete .complete-icon {
    font-size: 3rem;
    margin-bottom: 8px;
  }

  .match-complete h3 {
    font-size: 1.3rem;
    margin-bottom: 4px;
  }

  /* ===== GRAMMAR SECTION ===== */
  .grammar-lesson {
    background: linear-gradient(135deg, #4ECDC4 0%, #44A3AA 100%);
    color: white;
    padding: 20px;
    border-radius: 20px;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }

  .grammar-lesson h3 {
    font-size: 1.15rem;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .grammar-lesson h3::before {
    content: "💡";
    font-size: 1.3rem;
  }

  .grammar-examples {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .grammar-example {
    background: rgba(255, 255, 255, 0.2);
    padding: 10px 14px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .grammar-example .ex-emoji {
    font-size: 1.5rem;
  }

  .grammar-example .highlight {
    background: var(--accent);
    color: var(--text);
    padding: 2px 8px;
    border-radius: 6px;
    font-weight: 800;
  }

  .grammar-question {
    background: var(--card);
    border-radius: 20px;
    padding: 18px;
    margin-bottom: 14px;
    box-shadow: var(--shadow);
    transition: all 0.3s ease;
  }

  .grammar-question.answered-correct {
    border: 3px solid var(--success);
  }

  .grammar-question.answered-wrong {
    border: 3px solid var(--error);
  }

  .grammar-q-number {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .grammar-q-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 14px;
    line-height: 1.4;
  }

  .grammar-q-text .blank {
    display: inline-block;
    min-width: 80px;
    border-bottom: 3px solid var(--primary);
    margin: 0 4px;
    text-align: center;
    color: var(--primary);
    font-weight: 800;
  }

  .grammar-options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 10px;
  }

  .grammar-option {
    background: var(--bg);
    border: 2px solid transparent;
    border-radius: 12px;
    padding: 12px 8px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    text-align: center;
  }

  .grammar-option:active:not(:disabled) {
    transform: scale(0.95);
  }

  .grammar-option:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .grammar-option.selected-correct {
    background: var(--success);
    color: white;
    border-color: var(--success);
  }

  .grammar-option.selected-wrong {
    background: var(--error);
    color: white;
    border-color: var(--error);
  }

  .grammar-option.show-correct {
    background: #E8F8EA;
    color: var(--success);
    border-color: var(--success);
  }

  .grammar-feedback {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .grammar-feedback.show {
    display: block;
  }

  .grammar-feedback.correct {
    background: #E8F8EA;
    color: #2E7D32;
  }

  .grammar-feedback.wrong {
    background: #FFE8E8;
    color: #C62828;
  }

  .grammar-complete {
    background: linear-gradient(135deg, var(--success) 0%, #4CAF50 100%);
    color: white;
    padding: 20px;
    border-radius: 20px;
    text-align: center;
    margin-top: 16px;
    box-shadow: var(--shadow-lg);
    animation: fadeIn 0.5s ease;
  }

  .grammar-complete .complete-icon {
    font-size: 3rem;
    margin-bottom: 8px;
  }

  /* ===== CHALLENGE SECTION ===== */
  .challenge-intro {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 20px;
    border-radius: 20px;
    margin-bottom: 16px;
    text-align: center;
    box-shadow: var(--shadow);
  }

  .challenge-intro .intro-icon {
    font-size: 3rem;
    margin-bottom: 6px;
  }

  .challenge-intro h3 {
    font-size: 1.25rem;
    margin-bottom: 4px;
  }

  .challenge-intro p {
    font-size: 0.95rem;
    opacity: 0.95;
  }

  .challenge-progress {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .challenge-dot {
    width: 32px;
    height: 6px;
    border-radius: 3px;
    background: #E0E0E0;
    transition: background 0.3s ease;
  }

  .challenge-dot.active {
    background: var(--primary);
  }

  .challenge-dot.correct {
    background: var(--success);
  }

  .challenge-dot.wrong {
    background: var(--error);
  }

  .challenge-card {
    background: var(--card);
    border-radius: 24px;
    padding: 24px 20px;
    box-shadow: var(--shadow-lg);
    text-align: center;
    animation: fadeIn 0.4s ease;
  }

  .challenge-q-number {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .challenge-q-prompt {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 20px;
    line-height: 1.3;
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .challenge-q-prompt .emoji-prompt {
    font-size: 3rem;
    line-height: 1;
  }

  .challenge-q-prompt .blank {
    display: inline-block;
    min-width: 90px;
    border-bottom: 4px solid var(--primary);
    margin: 0 4px;
    color: var(--primary);
    font-weight: 900;
  }

  .challenge-options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }

  .challenge-option {
    background: var(--bg);
    border: 3px solid transparent;
    border-radius: 16px;
    padding: 16px;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    text-align: center;
    box-shadow: var(--shadow);
  }

  .challenge-option:active:not(:disabled) {
    transform: scale(0.97);
  }

  .challenge-option:disabled {
    cursor: not-allowed;
  }

  .challenge-option.selected-correct {
    background: var(--success);
    color: white;
    border-color: var(--success);
    animation: pop 0.4s ease;
  }

  .challenge-option.selected-wrong {
    background: var(--error);
    color: white;
    border-color: var(--error);
    animation: shake 0.4s ease;
  }

  .challenge-option.show-correct {
    background: #E8F8EA;
    color: var(--success);
    border-color: var(--success);
  }

  @keyframes pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  .challenge-feedback {
    padding: 12px 16px;
    border-radius: 14px;
    font-size: 1rem;
    font-weight: 700;
    display: none;
    margin-bottom: 14px;
    animation: fadeIn 0.3s ease;
  }

  .challenge-feedback.show {
    display: block;
  }

  .challenge-feedback.correct {
    background: #E8F8EA;
    color: #2E7D32;
  }

  .challenge-feedback.wrong {
    background: #FFE8E8;
    color: #C62828;
  }

  .challenge-next-btn {
    background: var(--primary);
    color: white;
    border: none;
    padding: 14px 32px;
    border-radius: 30px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: all 0.2s ease;
    font-family: inherit;
    display: none;
  }

  .challenge-next-btn.show {
    display: inline-block;
  }

  .challenge-next-btn:active {
    background: var(--primary-dark);
    transform: scale(0.97);
  }

  .challenge-result {
    background: linear-gradient(135deg, var(--accent) 0%, #FFB84D 100%);
    border-radius: 24px;
    padding: 28px 20px;
    text-align: center;
    box-shadow: var(--shadow-lg);
    animation: fadeIn 0.5s ease;
  }

  .challenge-result .result-icon {
    font-size: 4rem;
    margin-bottom: 8px;
    animation: bounce 1.5s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .challenge-result h3 {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 8px;
  }

  .challenge-result .result-score {
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .challenge-result .result-stars {
    font-size: 2rem;
    letter-spacing: 4px;
    margin-bottom: 16px;
    line-height: 1;
  }

  .challenge-restart-btn {
    background: var(--card);
    color: var(--primary-dark);
    border: 3px solid var(--primary);
    padding: 12px 28px;
    border-radius: 30px;
