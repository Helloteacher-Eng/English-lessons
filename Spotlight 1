<script>
  /* =========================================================
     STATE & PROGRESS TRACKING
     ========================================================= */
  const state = {
    currentTab: 'learn',
    stars: 0,
    completedSections: {
      learn: false,
      listen: false,
      match: false,
      grammar: false,
      challenge: false
    },
    totalSections: 5,
    learnHeard: new Set(),
    listenPlayed: new Set(),
    matchMatched: 0,
    grammarAnswered: 0,
    challengeScore: 0,
    celebrationShown: false
  };

  // Vocabulary for this lesson
  const vocabulary = [
    { word: 'father', emoji: '👨' },
    { word: 'mother', emoji: '👩' },
    { word: 'brother', emoji: '👦' },
    { word: 'sister', emoji: '👧' },
    { word: 'grandfather', emoji: '👴' },
    { word: 'grandmother', emoji: '👵' }
  ];

  // Grammar questions
  const grammarQuestions = [
    {
      text: '___ mother.',
      options: ['My', 'His', 'Her'],
      correct: 0,
      explanation: '"My" is used when talking about yourself (I → my).'
    },
    {
      text: 'Ahmed and ___ father.',
      options: ['My', 'His', 'Her'],
      correct: 1,
      explanation: 'Ahmed is a boy, so we use "his" (he → his).'
    },
    {
      text: 'Sara and ___ sister.',
      options: ['My', 'His', 'Her'],
      correct: 2,
      explanation: 'Sara is a girl, so we use "her" (she → her).'
    },
    {
      text: 'I love ___ family.',
      options: ['My', 'His', 'Her'],
      correct: 0,
      explanation: '"I" goes with "my" (I → my).'
    }
  ];

  // Challenge questions (mix of vocab + grammar)
  const challengeQuestions = [
    {
      type: 'vocab',
      prompt: '<span class="emoji-prompt">👨</span>',
      promptSpeak: 'Father',
      options: ['father', 'mother', 'brother'],
      correct: 0
    },
    {
      type: 'vocab',
      prompt: '<span class="emoji-prompt">👩</span>',
      promptSpeak: 'Mother',
      options: ['sister', 'grandmother', 'mother'],
      correct: 2
    },
    {
      type: 'grammar',
      prompt: 'Ahmed and <span class="blank">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> father.',
      promptSpeak: 'Ahmed and blank father.',
      options: ['My', 'His', 'Her'],
      correct: 1
    },
    {
      type: 'grammar',
      prompt: 'Sara and <span class="blank">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> sister.',
      promptSpeak: 'Sara and blank sister.',
      options: ['My', 'His', 'Her'],
      correct: 2
    },
    {
      type: 'vocab',
      prompt: 'My <span class="blank">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> <span class="emoji-prompt">👩</span>',
      promptSpeak: 'My blank.',
      options: ['father', 'mother', 'brother'],
      correct: 1
    }
  ];

  /* =========================================================
     DOM REFERENCES
     ========================================================= */
  const tabButtons = document.querySelectorAll('.tab-btn');
  const sections = document.querySelectorAll('.section');
  const progressFill = document.getElementById('progressFill');
  const progressPercent = document.getElementById('progressPercent');
  const starCounter = document.getElementById('starCounter');
  const resetBtn = document.getElementById('resetBtn');
  const celebrationModal = document.getElementById('celebrationModal');
  const modalCloseBtn = document.getElementById('modalCloseBtn');
  const confirmDialog = document.getElementById('confirmDialog');
  const confirmCancel = document.getElementById('confirmCancel');
  const confirmOk = document.getElementById('confirmOk');

  /* =========================================================
     REUSABLE SPEECH SYNTHESIS FUNCTION
     ========================================================= */
  function speak(text, options = {}) {
    const {
      lang = 'en-US',
      rate = 0.9,
      pitch = 1.0,
      volume = 1.0,
      onEnd = null,
      onStart = null
    } = options;

    if (!('speechSynthesis' in window)) {
      console.warn('Speech synthesis not supported.');
      if (typeof onEnd === 'function') onEnd();
      return;
    }

    window.speechSynthesis.cancel();

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = lang;
    utterance.rate = rate;
    utterance.pitch = pitch;
    utterance.volume = volume;

    if (typeof onStart === 'function') utterance.onstart = onStart;
    if (typeof onEnd === 'function') utterance.onend = onEnd;
    utterance.onerror = () => { if (typeof onEnd === 'function') onEnd(); };

    window.speechSynthesis.speak(utterance);
  }

  /* =========================================================
     TAB SWITCHING
     ========================================================= */
  function switchTab(tabName) {
    state.currentTab = tabName;
    tabButtons.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.tab === tabName);
    });
    sections.forEach(section => {
      section.classList.toggle('active', section.id === tabName);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab));
  });

  /* =========================================================
     PROGRESS & STARS
     ========================================================= */
  function updateProgress() {
    const completedCount = Object.values(state.completedSections)
      .filter(Boolean).length;
    const percent = Math.round((completedCount / state.totalSections) * 100);

    progressFill.style.width = percent + '%';
    progressPercent.textContent = percent + '%';
    starCounter.textContent = state.stars;

    // Update tab completion badges
    tabButtons.forEach(btn => {
      const tab = btn.dataset.tab;
      btn.classList.toggle('completed', !!state.completedSections[tab]);
    });

    saveState();

    // Check if all sections completed -> show celebration
    if (completedCount === state.totalSections && !state.celebrationShown) {
      state.celebrationShown = true;
      setTimeout(showCelebration, 800);
    }
  }

  function addStar(count = 1) {
    state.stars += count;
    updateProgress();
    starCounter.style.transform = 'scale(1.3)';
    setTimeout(() => { starCounter.style.transform = 'scale(1)'; }, 250);
  }

  function completeSection(sectionName) {
    if (state.completedSections[sectionName]) return;
    state.completedSections[sectionName] = true;
    updateProgress();
  }

  function saveState() {
    try {
      const saveState = {
        stars: state.stars,
        completedSections: state.completedSections,
        learnHeard: Array.from(state.learnHeard),
        listenPlayed: Array.from(state.listenPlayed),
        challengeScore: state.challengeScore,
        celebrationShown: state.celebrationShown
      };
      localStorage.setItem('meetMyFamilyState', JSON.stringify(saveState));
    } catch (e) { /* ignore */ }
  }

  /* =========================================================
     LEARN SECTION - VOCAB CARDS
     ========================================================= */
  function buildLearnSection() {
    const grid = document.getElementById('vocabGrid');
    grid.innerHTML = '';

    vocabulary.forEach((item) => {
      const card = document.createElement('div');
      card.className = 'vocab-card';
      card.dataset.word = item.word;
      card.innerHTML = `
        <div class="vocab-emoji">${item.emoji}</div>
        <div class="vocab-word">${item.word}</div>
        <button class="vocab-listen-btn" aria-label="Listen to ${item.word}">
          🔊 Listen
        </button>
      `;

      const listenBtn = card.querySelector('.vocab-listen-btn');

      const handleListen = (e) => {
        e.stopPropagation();
        speak(item.word, { rate: 0.85 });
        markLearnHeard(item.word, card);
      };

      listenBtn.addEventListener('click', handleListen);
      card.addEventListener('click', () => {
        speak(item.word, { rate: 0.85 });
        markLearnHeard(item.word, card);
      });

      grid.appendChild(card);
    });
  }

  function markLearnHeard(word, card) {
    state.learnHeard.add(word);
    card.classList.add('listened');
    if (state.learnHeard.size === vocabulary.length && !state.completedSections.learn) {
      completeSection('learn');
      addStar(2);
    }
    updateProgress();
  }

  /* =========================================================
     LISTEN SECTION - PRONUNCIATION BUTTONS
     ========================================================= */
  function buildListenSection() {
    const grid = document.getElementById('listenGrid');
    grid.innerHTML = '';

    vocabulary.forEach((item) => {
      const btn = document.createElement('button');
      btn.className = 'listen-btn';
      btn.dataset.word = item.word;
      btn.innerHTML = `
        <span class="listen-emoji">${item.emoji}</span>
        <span class="listen-word">${item.word}</span>
        <span class="listen-icon">🔊</span>
      `;

      btn.addEventListener('click', () => {
        if (btn.classList.contains('speaking')) return;

        btn.classList.add('speaking');
        speak(item.word, {
          rate: 0.8,
          onStart: () => { btn.classList.add('speaking'); },
          onEnd: () => {
            btn.classList.remove('speaking');
            markListenPlayed(item.word);
          }
        });

        setTimeout(() => {
          btn.classList.remove('speaking');
          markListenPlayed(item.word);
        }, 2000);
      });

      grid.appendChild(btn);
    });
  }

  function markListenPlayed(word) {
    state.listenPlayed.add(word);
    if (state.listenPlayed.size === vocabulary.length && !state.completedSections.listen) {
      completeSection('listen');
      addStar(2);
    }
    updateProgress();
  }

  /* =========================================================
     MATCH SECTION
     ========================================================= */
  let matchState = {
    selectedEmoji: null,
    selectedWord: null,
    matchedCount: 0
  };

  function shuffleArray(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function buildMatchSection() {
    const emojiCol = document.getElementById('emojiColumn');
    const wordCol = document.getElementById('wordColumn');
    document.getElementById('matchCompleteMsg').innerHTML = '';

    emojiCol.innerHTML = '<div class="match-column-title">Pictures</div>';
    wordCol.innerHTML = '<div class="match-column-title">Words</div>';

    const shuffledEmojis = shuffleArray(vocabulary);
    const shuffledWords = shuffleArray(vocabulary);

    shuffledEmojis.forEach((item) => {
      const el = document.createElement('button');
      el.className = 'match-item';
      el.dataset.word = item.word;
      el.dataset.type = 'emoji';
      el.innerHTML = `<span class="match-emoji">${item.emoji}</span>`;
      el.addEventListener('click', () => handleMatchClick(el));
      emojiCol.appendChild(el);
    });

    shuffledWords.forEach((item) => {
      const el = document.createElement('button');
      el.className = 'match-item';
      el.dataset.word = item.word;
      el.dataset.type = 'word';
      el.textContent = item.word;
      el.addEventListener('click', () => handleMatchClick(el));
      wordCol.appendChild(el);
    });

    matchState = { selectedEmoji: null, selectedWord: null, matchedCount: 0 };
  }

  function handleMatchClick(el) {
    if (el.classList.contains('correct')) return;

    const type = el.dataset.type;

    if (type === 'emoji') {
      if (matchState.selectedEmoji) {
        matchState.selectedEmoji.classList.remove('selected');
      }
      matchState.selectedEmoji = el;
      el.classList.add('selected');
    } else {
      if (matchState.selectedWord) {
        matchState.selectedWord.classList.remove('selected');
      }
      matchState.selectedWord = el;
      el.classList.add('selected');
    }

    if (matchState.selectedEmoji && matchState.selectedWord) {
      checkMatch();
    }
  }

  function checkMatch() {
    const emojiEl = matchState.selectedEmoji;
    const wordEl = matchState.selectedWord;

    if (emojiEl.dataset.word === wordEl.dataset.word) {
      emojiEl.classList.remove('selected');
      wordEl.classList.remove('selected');
      emojiEl.classList.add('correct');
      wordEl.classList.add('correct');

      matchState.matchedCount++;
      speak('Good!', { rate: 1.1, pitch: 1.3 });

      matchState.selectedEmoji = null;
      matchState.selectedWord = null;

      if (matchState.matchedCount === vocabulary.length) {
        completeMatchGame();
      }
    } else {
      emojiEl.classList.add('wrong');
      wordEl.classList.add('wrong');

      setTimeout(() => {
        emojiEl.classList.remove('wrong', 'selected');
        wordEl.classList.remove('wrong', 'selected');
        matchState.selectedEmoji = null;
        matchState.selectedWord = null;
      }, 600);
    }
    updateProgress();
  }

  function completeMatchGame() {
    if (state.completedSections.match) return;
    completeSection('match');
    addStar(3);

    const msg = document.getElementById('matchCompleteMsg');
    msg.innerHTML = `
      <div class="match-complete">
        <div class="complete-icon">🎉</div>
        <h3>Amazing Job!</h3>
        <p>You matched all the family members! +3 ⭐</p>
      </div>
    `;
    msg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* =========================================================
     GRAMMAR SECTION
     ========================================================= */
  let grammarState = {
    answered: 0,
    correct: 0
  };

  function buildGrammarSection() {
    const container = document.getElementById('grammarQuestions');
    document.getElementById('grammarCompleteMsg').innerHTML = '';
    container.innerHTML = '';
    grammarState = { answered: 0, correct: 0 };

    grammarQuestions.forEach((q, qIdx) => {
      const qCard = document.createElement('div');
      qCard.className = 'grammar-question';
      qCard.dataset.qidx = qIdx;

      const displayText = q.text.replace('___', '<span class="blank">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>');

      let optionsHTML = '';
      q.options.forEach((opt, oIdx) => {
        optionsHTML += `<button class="grammar-option" data-q="${qIdx}" data-o="${oIdx}">${opt}</button>`;
      });

      qCard.innerHTML = `
        <div class="grammar-q-number">Question ${qIdx + 1}</div>
        <div class="grammar-q-text">${displayText}</div>
        <div class="grammar-options">${optionsHTML}</div>
        <div class="grammar-feedback"></div>
      `;

      container.appendChild(qCard);
    });

    document.querySelectorAll('.grammar-option').forEach(btn => {
      btn.addEventListener('click', handleGrammarAnswer);
    });
  }

  function handleGrammarAnswer(e) {
    const btn = e.currentTarget;
    const qIdx = parseInt(btn.dataset.q);
    const oIdx = parseInt(btn.dataset.o);
    const q = grammarQuestions[qIdx];
    const qCard = btn.closest('.grammar-question');

    if (qCard.classList.contains('answered-correct') || qCard.classList.contains('answered-wrong')) return;

    const allOptions = qCard.querySelectorAll('.grammar-option');
    const feedback = qCard.querySelector('.grammar-feedback');
    const blank = qCard.querySelector('.blank');

    allOptions.forEach(o => o.disabled = true);

    if (oIdx === q.correct) {
      btn.classList.add('selected-correct');
      qCard.classList.add('answered-correct');
      blank.textContent = q.options[q.correct];
      blank.style.color = 'var(--success)';
      blank.style.borderColor = 'var(--success)';
      feedback.className = 'grammar-feedback show correct';
      feedback.innerHTML = `✅ <strong>Correct!</strong> ${q.explanation}`;
      grammarState.correct++;
      speak('Correct!', { rate: 1.1, pitch: 1.3 });
    } else {
      btn.classList.add('selected-wrong');
      allOptions[q.correct].classList.add('show-correct');
      qCard.classList.add('answered-wrong');
      blank.textContent = q.options[q.correct];
      blank.style.color = 'var(--error)';
      blank.style.borderColor = 'var(--error)';
      feedback.className = 'grammar-feedback show wrong';
      feedback.innerHTML = `❌ <strong>Not quite.</strong> The answer is <strong>${q.options[q.correct]}</strong>. ${q.explanation}`;
    }

    grammarState.answered++;

    if (grammarState.answered === grammarQuestions.length) {
      completeGrammar();
    }
    updateProgress();
  }

  function completeGrammar() {
    if (state.completedSections.grammar) return;
    completeSection('grammar');

    const stars = grammarState.correct === grammarQuestions.length ? 3 :
                  grammarState.correct >= 3 ? 2 : 1;
    addStar(stars);

    const msg = document.getElementById('grammarCompleteMsg');
    msg.innerHTML = `
      <div class="grammar-complete">
        <div class="complete-icon">🌟</div>
        <h3>Grammar Master!</h3>
        <p>You got ${grammarState.correct} out of ${grammarQuestions.length} correct! +${stars} ⭐</p>
      </div>
    `;
    msg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* =========================================================
     CHALLENGE SECTION
     ========================================================= */
  let challengeState = {
    currentIndex: 0,
    score: 0,
    answers: [], // 'correct' or 'wrong' per question
    finished: false
  };

  function buildChallengeSection() {
    challengeState = {
      currentIndex: 0,
      score: 0,
      answers: [],
      finished: false
    };

    // Build progress dots
    const progress = document.getElementById('challengeProgress');
    progress.innerHTML = '';
    for (let i = 0; i < challengeQuestions.length; i++) {
      const dot = document.createElement('div');
      dot.className = 'challenge-dot' + (i === 0 ? ' active' : '');
      progress.appendChild(dot);
    }

    renderChallengeQuestion();
  }

  function renderChallengeQuestion() {
    const container = document.getElementById('challengeContent');
    const q = challengeQuestions[challengeState.currentIndex];
    const qNum = challengeState.currentIndex + 1;

    container.innerHTML = `
      <div class="challenge-card">
        <div class="challenge-q-number">Question ${qNum} of ${challengeQuestions.length}</div>
        <div class="challenge-q-prompt">${q.prompt}</div>
        <div class="challenge-options" id="challengeOptions">
          ${q.options.map((opt, idx) => `
            <button class="challenge-option" data-idx="${idx}">${opt}</button>
          `).join('')}
        </div>
        <div class="challenge-feedback" id="challengeFeedback"></div>
        <button class="challenge-next-btn" id="challengeNextBtn">
          ${qNum === challengeQuestions.length ? 'See Results 🎯' : 'Next →'}
        </button>
      </div>
    `;

    // Speak the prompt
    setTimeout(() => {
      speak(q.promptSpeak, { rate: 0.85 });
    }, 300);

    // Attach option listeners
    document.querySelectorAll('.challenge-option').forEach(btn => {
      btn.addEventListener('click', handleChallengeAnswer);
    });

    document.getElementById('challengeNextBtn').addEventListener('click', handleChallengeNext);
  }

  function handleChallengeAnswer(e) {
    const btn = e.currentTarget;
    const idx = parseInt(btn.dataset.idx);
    const q = challengeQuestions[challengeState.currentIndex];
    const allOptions = document.querySelectorAll('#challengeOptions .challenge-option');
    const feedback = document.getElementById('challengeFeedback');
    const nextBtn = document.getElementById('challengeNextBtn');
    const blank = document.querySelector('.challenge-q-prompt .blank');

    // Disable all options
    allOptions.forEach(o => o.disabled = true);

    if (idx === q.correct) {
      btn.classList.add('selected-correct');
      feedback.className = 'challenge-feedback show correct';
      feedback.innerHTML = '✅ Correct! Well done!';
      challengeState.score++;
      challengeState.answers.push('correct');
      if (blank) {
        blank.textContent = q.options[q.correct];
        blank.style.color = 'var(--success)';
        blank.style.borderColor = 'var(--success)';
      }
      speak('Correct!', { rate: 1.1, pitch: 1.3 });
    } else {
      btn.classList.add('selected-wrong');
      allOptions[q.correct].classList.add('show-correct');
      feedback.className = 'challenge-feedback show wrong';
      feedback.innerHTML = `❌ The answer is <strong>${q.options[q.correct]}</strong>.`;
      challengeState.answers.push('wrong');
      if (blank) {
        blank.textContent = q.options[q.correct];
        blank.style.color = 'var(--error)';
        blank.style.borderColor = 'var(--error)';
      }
    }

    // Update progress dot
    const dots = document.querySelectorAll('.challenge-dot');
    dots[challengeState.currentIndex].classList.remove('active');
    dots[challengeState.currentIndex].classList.add(idx === q.correct ? 'correct' : 'wrong');

    nextBtn.classList.add('show');
  }

  function handleChallengeNext() {
    challengeState.currentIndex++;

    if (challengeState.currentIndex >= challengeQuestions.length) {
      finishChallenge();
    } else {
      // Update active dot
      const dots = document.querySelectorAll('.challenge-dot');
      dots[challengeState.currentIndex].classList.add('active');
      renderChallengeQuestion();
    }
  }

  function finishChallenge() {
    challengeState.finished = true;
    state.challengeScore = challengeState.score;

    // Award stars based on score (1-5)
    const starsAwarded = Math.max(1, challengeState.score);
    addStar(starsAwarded);

    // Mark section complete
    if (!state.completedSections.challenge) {
      completeSection('challenge');
    }

    // Show result card
    const container = document.getElementById('challengeContent');
    const starsDisplay = '⭐'.repeat(starsAwarded) + '<span style="opacity:0.25">' + '⭐'.repeat(5 - starsAwarded) + '</span>';

    let message = '';
    let icon = '';
    if (challengeState.score === 5) {
      message = 'Perfect Score!';
      icon = '🏆';
    } else if (challengeState.score >= 4) {
      message = 'Great Job!';
      icon = '🌟';
    } else if (challengeState.score >= 3) {
      message = 'Good Work!';
      icon = '👍';
    } else if (challengeState.score >= 2) {
      message = 'Nice Try!';
      icon = '💪';
    } else {
      message = 'Keep Practicing!';
      icon = '📚';
    }

    container.innerHTML = `
      <div class="challenge-result">
        <div class="result-icon">${icon}</div>
        <h3>${message}</h3>
        <p class="result-score">You got <strong>${challengeState.score} out of ${challengeQuestions.length}</strong> correct!</p>
        <div class="result-stars">${starsDisplay}</div>
        <button class="challenge-restart-btn" id="challengeRestartBtn">🔄 Try Again</button>
      </div>
    `;

    document.getElementById('challengeRestartBtn').addEventListener('click', () => {
      buildChallengeSection();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Launch confetti if perfect score
    if (challengeState.score === 5) {
      setTimeout(launchConfetti, 400);
    }
  }

  /* =========================================================
     CELEBRATION MODAL
     ========================================================= */
  function showCelebration() {
    const modalScore = document.getElementById('modalScore');
    const modalStars = document.getElementById('modalStars');
    const modalProgress = document.getElementById('modalProgress');
    const modalStarsDisplay = document.getElementById('modalStarsDisplay');

    modalScore.textContent = `${state.challengeScore}/${challengeQuestions.length}`;
    modalStars.textContent = `⭐ ${state.stars}`;
    modalProgress.textContent = '100%';

    // Stars display based on challenge score (1-5)
    const starsCount = Math.max(1, state.challengeScore);
    modalStarsDisplay.textContent = '⭐'.repeat(starsCount);

    celebrationModal.classList.add('show');
    launchConfetti();
  }

  modalCloseBtn.addEventListener('click', () => {
    celebrationModal.classList.remove('show');
  });

  celebrationModal.addEventListener('click', (e) => {
    if (e.target === celebrationModal) {
      celebrationModal.classList.remove('show');
    }
  });

  /* =========================================================
     CONFETTI ANIMATION (Canvas-based, no libraries)
     ========================================================= */
  function launchConfetti() {
    const canvas = document.createElement('canvas');
    canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
    document.body.appendChild(canvas);
    const ctx = canvas.getContext('2d');

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const colors = ['#FF8C42', '#4ECDC4', '#FFD93D', '#6BCB77', '#FF6B6B', '#A78BFA', '#FFB84D'];
    const particles = [];
    const PARTICLE_COUNT = 120;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * canvas.height * 0.5,
        w: 6 + Math.random() * 8,
        h: 4 + Math.random() * 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        vx: (Math.random() - 0.5) * 4,
        vy: 2 + Math.random() * 3,
        rotation: Math.random() * Math.PI * 2,
        rotationSpeed: (Math.random() - 0.5) * 0.2,
        opacity: 1
      });
    }

    const startTime = Date.now();
    const DURATION = 4500;

    function animate() {
      const elapsed = Date.now() - startTime;

      if (elapsed > DURATION) {
        canvas.remove();
        window.removeEventListener('resize', resize);
        return;
      }

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Fade out in the last second
      const fadeStart = DURATION - 1000;
      const globalAlpha = elapsed > fadeStart ? (DURATION - elapsed) / 1000 : 1;

      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.08; // gravity
        p.rotation += p.rotationSpeed;

        ctx.save();
        ctx.globalAlpha = globalAlpha;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
        ctx.restore();
      });

      requestAnimationFrame(animate);
    }

    animate();
  }

  /* =========================================================
     RESET LESSON
     ========================================================= */
  resetBtn.addEventListener('click', () => {
    confirmDialog.classList.add('show');
  });

  confirmCancel.addEventListener('click', () => {
    confirmDialog.classList.remove('show');
  });

  confirmOk.addEventListener('click', () => {
    confirmDialog.classList.remove('show');
    resetLesson();
  });

  confirmDialog.addEventListener('click', (e) => {
    if (e.target === confirmDialog) {
      confirmDialog.classList.remove('show');
    }
  });

  function resetLesson() {
    // Reset state
    state.stars = 0;
    state.learnHeard = new Set();
    state.listenPlayed = new Set();
    state.matchMatched = 0;
    state.grammarAnswered = 0;
    state.challengeScore = 0;
    state.celebrationShown = false;
    Object.keys(state.completedSections).forEach(k => {
      state.completedSections[k] = false;
    });

    // Clear storage
    try { localStorage.removeItem('meetMyFamilyState'); } catch (e) {}

    // Rebuild all sections
    buildLearnSection();
    buildListenSection();
    buildMatchSection();
    buildGrammarSection();
    buildChallengeSection();

    // Update UI
    updateProgress();
    switchTab('learn');

    // Close celebration modal if open
    celebrationModal.classList.remove('show');
  }

  /* =========================================================
     INIT
     ========================================================= */
  function init() {
    // Try to restore saved state
    try {
      const saved = localStorage.getItem('meetMyFamilyState');
      if (saved) {
        const parsed = JSON.parse(saved);
        state.stars = parsed.stars || 0;
        state.completedSections = parsed.completedSections || state.completedSections;
        state.learnHeard = new Set(parsed.learnHeard || []);
        state.listenPlayed = new Set(parsed.listenPlayed || []);
        state.challengeScore = parsed.challengeScore || 0;
        state.celebrationShown = parsed.celebrationShown || false;
      }
    } catch (e) { /* ignore */ }

    // Build all sections
    buildLearnSection();
    buildListenSection();
    buildMatchSection();
    buildGrammarSection();
    buildChallengeSection();

    // Restore visual state for Learn section
    document.querySelectorAll('.vocab-card').forEach(card => {
      if (state.learnHeard.has(card.dataset.word)) {
        card.classList.add('listened');
      }
    });

    updateProgress();
    switchTab('learn');
  }

  // Expose API for debugging / future use
  window.lesson = {
    state,
    vocabulary,
    speak,
    switchTab,
    addStar,
    completeSection,
    updateProgress,
    resetLesson,
    launchConfetti
  };

  init();
</script>

</body>
</html>
